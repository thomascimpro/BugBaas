<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widgetRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/bug_radar_widget_background">

  <ImageView
    android:id="@+id/radarBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:alpha="0.96"
    android:contentDescription="@null"
    android:scaleType="centerCrop"
    android:src="@drawable/bug_radar_scan_animation" />

  <ImageView
    android:id="@+id/radarBugImage"
    android:layout_width="86dp"
    android:layout_height="70dp"
    android:layout_gravity="center"
    android:contentDescription="@null"
    android:scaleType="fitCenter"
    android:src="@drawable/bugdex_zilvervisje"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/radarLabel"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bug_radar_label_background"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:visibility="gone">

    <TextView
      android:id="@+id/radarBugName"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:ellipsize="end"
      android:gravity="center"
      android:maxLines="1"
      android:textColor="#FFFFFF"
      android:textSize="12sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/radarRarity"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="6dp"
      android:textColor="#D7BD57"
      android:textSize="10sp"
      android:textStyle="bold" />
  </LinearLayout>
</FrameLayout>
