{
  "name": "bugbaas",
  "version": "2.10.3",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "web:export": "expo export --platform web --output-dir site/public/game && node scripts/prepare_web_export.mjs",
    "site:build": "npm --prefix site run build",
    "android": "expo run:android",
    "apk:release": "cd android && gradlew.bat :app:assembleRelease --console=plain",
    "apk:fast": "cd android && gradlew.bat :app:assembleRelease --console=plain -Pandroid.enableMinifyInReleaseBuilds=false -Pandroid.enableShrinkResourcesInReleaseBuilds=false -Pandroid.enablePngCrunchInReleaseBuilds=false",
    "typecheck": "tsc --noEmit",
    "test:arcade": "node scripts/test_arcade_gameplay.mjs",
    "test:arcade:web": "node scripts/playtest_arcade_web.mjs",
    "seed:cimpro-org": "node scripts/seed_cimpro_organization.mjs",
    "season:close-duel": "node scripts/close_duel_season.mjs",
    "wiki:deploy": "npx netlify-cli deploy --dir bugbaas-wiki",
    "wiki:deploy:prod": "npx netlify-cli deploy --prod --dir bugbaas-wiki",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.0",
    "expo-notifications": "~0.32.17",
    "firebase": "^12.0.0",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^5.9.0"
  }
}
